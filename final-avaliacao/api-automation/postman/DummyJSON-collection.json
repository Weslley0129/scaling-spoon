        "url": "{{baseUrl}}/users/add"
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
        "pm.test('Tempo < 2s', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
        "const json = pm.response.json();",
        "pm.test('Campos obrigatorios', function () { pm.expect(json).to.have.property('id'); pm.expect(json).to.have.property('firstName'); });",
        "pm.environment.set('userId', json.id);"
      ], "type": "text/javascript" } }]
    },
    {
      "name": "Users - Update",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"age\": 30\n}" },
        "url": "{{baseUrl}}/users/{{userId}}"
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
        "pm.test('Tempo < 2s', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
        "const json = pm.response.json();",
