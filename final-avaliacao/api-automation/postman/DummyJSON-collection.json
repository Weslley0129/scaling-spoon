    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"emilys\",\n  \"password\": \"emilyspass\",\n  \"expiresInMins\": 30\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
        "pm.test('Tempo < 2s', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
        "const json = pm.response.json();",
        "pm.test('Retorna token e id', function () { pm.expect(json).to.have.property('accessToken'); pm.expect(json).to.have.property('id'); });",
        "pm.environment.set('authToken', json.accessToken);",
        "pm.environment.set('authUserId', json.id);"
      ], "type": "text/javascript" } }]
    },
    {
      "name": "Auth - Me (com token)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
        "url": "{{baseUrl}}/auth/me"
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
        "pm.test('Tempo < 2s', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
        "const json = pm.response.json();",
        "pm.test('Usuario autenticado correto', function () { pm.expect(json.id).to.eql(Number(pm.environment.get('authUserId'))); });",
        "pm.test('Estrutura minima', function () { pm.expect(json).to.have.property('username'); pm.expect(json).to.have.property('email'); });"
      ], "type": "text/javascript" } }]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "https://dummyjson.com" }
  ]
}
