{
  "info": {
    "name": "DummyJSON API Automation",
    "_postman_id": "e669f988-ec1f-4fc7-a58b-53ca70ef6417",
    "description": "Colecao para atividade final de Qualidade e Teste de Software",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Products - Add",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Produto Teste QA\",\n  \"price\": 999\n}"
        },
        "url": "{{baseUrl}}/products/add"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "pm.test('Tempo < 2s', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
              "const json = pm.response.json();",
              "pm.test('Campos obrigatorios', function () { pm.expect(json).to.have.property('id'); pm.expect(json).to.have.property('title'); });",
              "pm.environment.set('productId', json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Products - Update",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"price\": 1099\n}" },
        "url": "{{baseUrl}}/products/{{productId}}"
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
        "pm.test('Tempo < 2s', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
        "const json = pm.response.json();",
        "pm.test('Retorna id e price', function () { pm.expect(json).to.have.property('id'); pm.expect(json).to.have.property('price'); });"
      ], "type": "text/javascript" } }]
    },
    {
      "name": "Products - Delete",
      "request": { "method": "DELETE", "url": "{{baseUrl}}/products/{{productId}}" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
        "pm.test('Tempo < 2s', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
        "const json = pm.response.json();",
        "pm.test('Retorna isDeleted', function () { pm.expect(json).to.have.property('isDeleted'); });"
      ], "type": "text/javascript" } }]
    },
    {
      "name": "Users - Add",
      "request": {
